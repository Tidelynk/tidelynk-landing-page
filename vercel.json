{
  "redirects": [
    {
      "source": "/join-now",
      "destination": "/",
      "permanent": true
    },
    {
      "source": "/contact-us",
      "destination": "/#contact",
      "permanent": true
    },
    {
      "source": "/cleaning-service/standard-clean",
      "destination": "/",
      "permanent": true
    },
    {
      "source": "/faqs",
      "destination": "/#faq",
      "permanent": true
    }
  ],
  "rewrites": [
    { "source": "/privacy-policy", "destination": "/privacy-policy.html" },
    { "source": "/terms-of-use",   "destination": "/terms-of-use.html"   },
    { "source": "/(.*)",            "destination": "/index.html"           }
  ]
}
